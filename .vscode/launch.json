{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Sphinx Doctor Extension Host",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--new-window",
				"--disable-extensions",
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}/tests/fixtures/simple-sphinx"
			],
			"outFiles": [
				"${workspaceFolder}/out/**/*.js"
			],
			"preLaunchTask": "npm: compile"
		},
		{
			"name": "Run Sphinx Doctor Extension Host (Workspace Extensions Enabled)",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--new-window",
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}/tests/fixtures/simple-sphinx"
			],
			"outFiles": [
				"${workspaceFolder}/out/**/*.js"
			],
			"preLaunchTask": "npm: compile"
		},
		{
			"name": "Run Sphinx Doctor Extension Host (Multi-Root Fixture Example)",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--new-window",
				"--disable-extensions",
				"--extensionDevelopmentPath=${workspaceFolder}",
				"${workspaceFolder}/tests/fixtures/simple-sphinx",
				"${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/out/**/*.js"
			],
			"preLaunchTask": "npm: compile"
		},
		{
			"name": "Run Sphinx Doctor Integration Tests",
			"type": "extensionHost",
			"request": "launch",
			"runtimeExecutable": "${execPath}",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}"
			],
			"outFiles": [
				"${workspaceFolder}/out/**/*.js"
			],
			"testConfiguration": "${workspaceFolder}/.vscode-test.mjs",
			"preLaunchTask": "Sphinx Doctor: Compile"
		}
	]
}