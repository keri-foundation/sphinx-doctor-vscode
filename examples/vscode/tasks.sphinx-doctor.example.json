{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sphinx-doctor-project-problems",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "sphinx_doctor.cli",
        "problems",
        "--diagnostics-json",
        "${workspaceFolder:example-sphinx-project}/.sphinx-diagnostics/latest.json",
        "--format",
        "vscode"
      ],
      "options": {
        "cwd": "${workspaceFolder:example-workspace}"
      },
      "problemMatcher": {
        "owner": "sphinx-doctor",
        "fileLocation": [
          "relative",
          "${workspaceFolder:example-sphinx-project}"
        ],
        "pattern": {
          "regexp": "^([^:]+):(\\d+):(\\d+):\\s+(error|warning|info):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    }
  ]
}